{
  "name": "Market Data Skills",
  "version": "1.0.0",
  "description": "Market data source routing for Databento and Alpha Vantage MCP workflows",
  "author": "DataBento MCP Server Team",
  "skills": [
    {
      "name": "market-data",
      "path": "market-data/SKILL.md",
      "description": "Market data source routing for Databento and Alpha Vantage MCP workflows",
      "version": "1.0.0",
      "type": "data-api",
      "scripts": [
        {
          "name": "get-quote",
          "path": "market-data/scripts/get-quote.js",
          "description": "Get real-time futures quotes (ES, NQ)"
        },
        {
          "name": "get-historical",
          "path": "market-data/scripts/get-historical.js",
          "description": "Get historical OHLCV bars for futures"
        },
        {
          "name": "get-session",
          "path": "market-data/scripts/get-session.js",
          "description": "Get current trading session info"
        },
        {
          "name": "resolve-symbols",
          "path": "market-data/scripts/resolve-symbols.js",
          "description": "Resolve symbols across different types"
        },
        {
          "name": "timeseries",
          "path": "market-data/scripts/timeseries.js",
          "description": "Get covered Standard CME historical timeseries data"
        },
        {
          "name": "metadata",
          "path": "market-data/scripts/metadata.js",
          "description": "Query datasets, schemas, fields, and costs"
        },
        {
          "name": "batch",
          "path": "market-data/scripts/batch.js",
          "description": "Submit and manage batch download jobs"
        },
        {
          "name": "reference",
          "path": "market-data/scripts/reference.js",
          "description": "Access security master and reference data"
        }
      ]
    }
  ],
  "metadata": {
    "created": "2025-10-19",
    "updated": "2026-06-16",
    "repository": "https://github.com/dqdp/databento-mcp-server",
    "compatibility": {
      "claude_code": ">=1.0.0",
      "node": ">=22.15.0",
      "module_type": "CommonJS"
    }
  },
  "triggers": {
    "automatic": [
      {
        "pattern": "databento",
        "skill": "market-data"
      },
      {
        "pattern": "cme market data",
        "skill": "market-data"
      },
      {
        "pattern": "standard cme",
        "skill": "market-data"
      },
      {
        "pattern": "futures quote",
        "skill": "market-data"
      },
      {
        "pattern": "futures historical bars",
        "skill": "market-data"
      },
      {
        "pattern": "cme options",
        "skill": "market-data"
      }
    ]
  },
  "configuration": {
    "required_env": [
      "DATABENTO_API_KEY"
    ],
    "auto_compose": true,
    "load_on_demand": true
  }
}
